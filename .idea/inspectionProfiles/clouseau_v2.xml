                        <option name="cleanup" value="true" />
                        <option name="description" value="Reports blank lines in Javadoc comments.&#10;&lt;p&gt;&#10;Blank lines in Javadoc may signal an intention split the text to different paragraphs. However, the Javadoc tool and IntelliJ IDEA will ignore them when rendering documentation comments.&#10;&lt;p&gt;&#10;The quick-fix suggests to replace the blank line with a paragraph tag (&lt;code&gt;&lt;​p&gt;&lt;/code&gt;).&#10;&lt;p&gt;&#10;&lt;b&gt;Example:&lt;/b&gt;&#10;&lt;pre&gt;&lt;code&gt;&#10;class Main {&#10;  /**&#10;   * Doesn't do anything.&#10;   *&#10;   * Does absolutely nothing&#10;   */&#10;  void foo() {}&#10;}&#10;&lt;/pre&gt;&lt;/code&gt;&#10;After the quick-fix is applied:&#10;&lt;pre&gt;&lt;code&gt;&#10;class Main {&#10;  /**&#10;   * Doesn't do anything.&#10;   * &lt;​p&gt;&#10;   * Does absolutely nothing&#10;   */&#10;  void foo() {}&#10;}&#10;&lt;/pre&gt;&lt;/code&gt;" />
                        <option name="name" value="Fixed Blank Line" />
                        <option name="problemDescriptor" value="insert &lt;p&gt;" />
                        <option name="suppressId" value="JavadocBlankLines" />
                        <option name="uuid" value="26d10e73-608d-3da5-86fa-65dd193e5d78" />
                        <option name="patterns">
                            <list>
                                <InspectionPattern>
                                    <option name="regExp" value="(?&lt;!Fraunhofer ISE|https://www\.eclipse\.org/legal/epl-2\.0\.)(\n\s*\*\s*)(?=\n\s*\* ?[^@ ])" />
                                    <option name="_fileType" value="JAVA" />
                                    <option name="searchContext" value="IN_COMMENTS" />
                                    <option name="replacement" value="$1 &lt;p&gt;" />
                                    <option name="flags" value="96" />
                                </InspectionPattern>
                            </list>
                        </option>
                    </RegExpInspectionConfiguration>
                </list>
